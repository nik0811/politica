# ============================================================================
# Politica Platform — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================================

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=politica_dev_pass

# ─── Storage ─────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ─── Security ────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-use-openssl-rand-hex-32
JWT_SECRET=change-me-use-openssl-rand-hex-32

# ─── LLM Provider (LiteLLM) ──────────────────────────────────────────────────
# Choose one provider. Defaults to local Ollama (free, private).

# Option 1: Ollama (local, free)
LLM_PROVIDER=ollama
LLM_MODEL=ollama/llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# Option 2: OpenAI
# LLM_PROVIDER=openai
# LLM_MODEL=openai/gpt-4o
# OPENAI_API_KEY=sk-...

# Option 3: AWS Bedrock
# LLM_PROVIDER=bedrock
# LLM_MODEL=bedrock/anthropic.claude-3-sonnet-20240229-v1:0
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION_NAME=us-east-1
