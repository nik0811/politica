# Python Backend Standards

## FastAPI Route Patterns

### Standard CRUD Routes

```python
from fastapi import APIRouter, Depends, HTTPException
from sqlalchemy.orm import Session

router = APIRouter()

# ✅ GOOD: Clear, consistent pattern
@router.get("/", response_model=List[ModelSchema])
async def list_items(
    skip: int = 0,
    limit: int = 20,
    db: Session = Depends(get_db)
):
    """List all items with pagination"""
    return db.query(Model).offset(skip).limit(limit).all()

@router.get("/{item_id}", response_model=ModelSchema)
async def get_item(item_id: str, db: Session = Depends(get_db)):
    """Get a single item by ID"""
    item = db.query(Model).filter(Model.id == item_id).first()
    if not item:
        raise HTTPException(status_code=404, detail="Item not found")
    return item

@router.post("/", response_model=ModelSchema, status_code=201)
async def create_item(item: ModelCreate, db: Session = Depends(get_db)):
    """Create a new item"""
    db_item = Model(**item.dict())
    db.add(db_item)
    db.commit()
    db.refresh(db_item)
    return db_item
```

## SQLAlchemy Models

### Keep Models Clean

```python
# ✅ GOOD: Focused model
class Document(Base):
    __tablename__ = "documents"
    
    id = Column(String, primary_key=True, default=generate_uuid)
    title = Column(String, nullable=False, index=True)
    content = Column(Text, nullable=False)
    created_at = Column(DateTime, server_default=func.now())
    updated_at = Column(DateTime, onupdate=func.now())

# ❌ BAD: Business logic in model
class Document(Base):
    def process_content(self):
        # Complex processing logic
        pass
    
    def analyze_sentiment(self):
        # ML logic
        pass
```

## Dependency Injection

```python
# ✅ GOOD: Reusable dependencies
def get_db():
    db = SessionLocal()
    try:
        yield db
    finally:
        db.close()

def get_current_user(token: str = Depends(oauth2_scheme)):
    return verify_token(token)

@router.get("/")
async def route(
    db: Session = Depends(get_db),
    user: User = Depends(get_current_user)
):
    pass
```

## Error Handling

```python
# ✅ GOOD: Specific exceptions
from fastapi import HTTPException

if not document:
    raise HTTPException(
        status_code=404,
        detail=f"Document {doc_id} not found"
    )

# ❌ BAD: Generic exceptions
if not document:
    raise Exception("Error")
```

## Async/Await

```python
# ✅ GOOD: Async where it helps
@router.get("/")
async def get_items(db: Session = Depends(get_db)):
    # DB calls are sync, but route is async for FastAPI
    return db.query(Model).all()

# ✅ GOOD: Actual async operations
@router.get("/external")
async def fetch_external():
    async with httpx.AsyncClient() as client:
        response = await client.get("https://api.example.com")
        return response.json()
```
