# .env.production template
# Copy this to .env.production and fill in the values

# Database
POSTGRES_USER=politica
POSTGRES_PASSWORD=<GENERATE_SECURE_PASSWORD>
DATABASE_URL=postgresql://politica:<POSTGRES_PASSWORD>@postgres:5432/politica

# Redis
REDIS_PASSWORD=<GENERATE_SECURE_PASSWORD>
REDIS_URL=redis://:<REDIS_PASSWORD>@redis:6379

# MinIO
MINIO_ROOT_USER=<GENERATE_SECURE_USERNAME>
MINIO_ROOT_PASSWORD=<GENERATE_SECURE_PASSWORD>

# API
API_SECRET_KEY=<GENERATE_SECRET_KEY>
ENVIRONMENT=production

# Optional: OpenAI API (for LLM features)
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>

# Optional: Monitoring
SENTRY_DSN=<YOUR_SENTRY_DSN>
