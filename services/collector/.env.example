# Node environment
NODE_ENV=development

# Database
DATABASE_URL=postgresql://politica:politica_dev_pass@localhost:5432/politica

# Redis
REDIS_URL=redis://localhost:6379

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# Browser settings
BROWSER_MODE=headless
STEALTH_MODE=true
MAX_CONCURRENT_BROWSERS=3

# Collection settings
RETRY_ATTEMPTS=3
RETRY_DELAY_MS=5000
